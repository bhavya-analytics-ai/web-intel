# Firecrawl — use cloud key OR point to self-hosted Hetzner server
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_URL=https://api.firecrawl.dev   # swap to http://your-hetzner-ip:3002 when ready

# LLM provider — pick one per system
WEB_INTEL_PROVIDER=openai               # openai | nvidia | anthropic
WEB_INTEL_API_KEY=sk-your-key-here
WEB_INTEL_MODEL=gpt-4o-mini

# NVIDIA NIM example (for TRUMAN)
# WEB_INTEL_PROVIDER=nvidia
# WEB_INTEL_API_KEY=your-nvidia-key
# WEB_INTEL_MODEL=meta/llama-3.3-70b-instruct
# WEB_INTEL_BASE_URL=https://integrate.api.nvidia.com/v1
